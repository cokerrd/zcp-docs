---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
import { COMMIT_SHA, BUILD_DATE } from '../../build-info.mjs';

const localePrefix = Astro.locals.starlightRoute.locale === 'fr' ? '/fr' : '';
---

<Default {...Astro.props} />

<div class="site-footer">
  <div class="site-footer__inner">
    <nav class="site-footer__nav" aria-label={Astro.locals.t('zs.footer.navLabel')}>
      <a href={`${localePrefix}/public-cloud/getting-started/introduction`}>ZCP</a>
      <a href={`${localePrefix}/private-cloud/overview`}>ZPCP</a>
      <a href={`${localePrefix}/public-cloud/cli/installation`}>CLI</a>
      <a href={`${localePrefix}/public-cloud/api/authentication`}>API</a>
      <a href="https://zcp.zsoftly.ca" target="_blank" rel="noopener noreferrer"
        >{Astro.locals.t('zs.footer.website')}</a
      >
      <a href="https://zcp.zsoftly.ca/pricing" target="_blank" rel="noopener noreferrer"
        >{Astro.locals.t('zs.footer.pricing')}</a
      >
      <a href="https://zcp.zsoftly.ca/contact" target="_blank" rel="noopener noreferrer"
        >{Astro.locals.t('zs.footer.contact')}</a
      >
      <a href="https://cloud.zcp.zsoftly.ca" target="_blank" rel="noopener noreferrer"
        >{Astro.locals.t('zs.footer.console')}</a
      >
      <a href="https://github.com/zsoftly/zcp-docs" target="_blank" rel="noopener noreferrer"
        >GitHub</a
      >
    </nav>
    <p class="site-footer__copy">
      © {new Date().getFullYear()} ZSoftly Technologies Inc.
      <a
        class="site-footer__version"
        href={`https://github.com/zsoftly/zcp-docs/commit/${COMMIT_SHA}`}
        target="_blank"
        rel="noopener noreferrer"
        title={`${Astro.locals.t('zs.footer.build')} ${COMMIT_SHA} · ${BUILD_DATE}`}
      >
        {COMMIT_SHA} · {BUILD_DATE}
      </a>
    </p>
  </div>
</div>

<style>
  .site-footer__version {
    margin-inline-start: 0.75rem;
    font-size: 0.7rem;
    color: var(--sl-color-gray-4);
    font-variant-numeric: tabular-nums;
    text-decoration: none;
  }
  .site-footer__version:hover {
    color: var(--sl-color-gray-3);
    text-decoration: underline;
  }
</style>
